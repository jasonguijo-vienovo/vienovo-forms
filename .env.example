# ─── MongoDB ───────────────────────────────────────────────────────────
# Matches credentials in docker-compose.yml. ?authSource=admin is required
# because the user is created against the admin database.
MONGODB_URI=mongodb://vienovo:vienovo_dev_password@localhost:27018/vienovo_forms?authSource=admin

# ─── NextAuth / Auth.js ────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-32-byte-random-string
AUTH_URL=http://localhost:3000

# ─── Microsoft Entra ID (Azure AD) ─────────────────────────────────────
# Create an app registration at https://entra.microsoft.com -> App registrations.
# Redirect URI for local dev: http://localhost:3000/api/auth/callback/microsoft-entra-id
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# Use your Vienovo tenant ID to restrict sign-in to org accounts only.
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<TENANT_ID>/v2.0

# Firebase Authentication (optional second sign-in path)
# Register a web app in Firebase, enable Google sign-in in Auth, and add a service account
# from Project settings -> Service accounts so the server can verify Firebase ID tokens.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Comma-separated list of @vienovo.ph emails who get the "Admin" nav link
# and access to /admin/*. Bootstrap method until role is moved into MongoDB.
ADMIN_EMAILS=jerome.corpus@vienovo.ph

# ─── Google Sheets ─────────────────────────────────────────────────────
# Path to the service account JSON key file. Generate one in Google Cloud
# Console and share the master sheet with the service account's email.
# Alternative to GOOGLE_SERVICE_ACCOUNT_KEY_PATH on hosted environments:
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./.secrets/google-sheets-sa.json
GOOGLE_SHEETS_MASTER_ID=1Sj-3cqo3k9RwTH2r4QOyGckyzboC4Z3zG5VNaTeGFj8

# Google Drive attachments
# Share one central Drive folder with the same service account, then paste
# that folder ID here. Uploads are organized under:
#   root folder / form slug / request reference
GOOGLE_DRIVE_ATTACHMENTS_ROOT_FOLDER_ID=

# ─── Microsoft Graph (for Teams notifications, milestone 6) ────────────
# Use an Entra ID app registration with admin-consented application permissions.
# Minimum for employee directory sync: User.Read.All
# Optional for Intune device summaries: DeviceManagementManagedDevices.Read.All
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SCOPE=https://graph.microsoft.com/.default
# Optional: ordered fallback fields to check for employee IDs during Graph sync.
# Example: employeeId,onPremisesExtensionAttributes.extensionAttribute3
GRAPH_EMPLOYEE_ID_FIELDS=employeeId,onPremisesExtensionAttributes.extensionAttribute1,onPremisesExtensionAttributes.extensionAttribute2,onPremisesExtensionAttributes.extensionAttribute3
INTUNE_SYNC_ENABLED=0
INTUNE_ALLOWED_EMAIL_DOMAIN=vienovo.ph
INTUNE_SYNC_INCLUDE_DEVICES=0
INTUNE_SYNC_PAGE_SIZE=100

# ─── Email (Resend, milestone 6) ───────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=SAP <sap@vienovo.ph>

# Email (SMTP notifications)
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SAP <sap@vienovo.ph>
# Optional (defaults work for Office365)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=0
