# ─── MongoDB ───────────────────────────────────────────────────────────
# Matches credentials in docker-compose.yml. ?authSource=admin is required
# because the user is created against the admin database.
MONGODB_URI=mongodb://vienovo:vienovo_dev_password@localhost:27018/vienovo_forms?authSource=admin

# ─── NextAuth / Auth.js ────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-32-byte-random-string
AUTH_URL=http://localhost:3000

# ─── Microsoft Entra ID (Azure AD) ─────────────────────────────────────
# Create an app registration at https://entra.microsoft.com -> App registrations.
# Redirect URI for local dev: http://localhost:3000/api/auth/callback/microsoft-entra-id
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# Use your Vienovo tenant ID to restrict sign-in to org accounts only.
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<TENANT_ID>/v2.0

# Set to 1 during local dev to bypass Microsoft sign-in and impersonate a fake user.
# Leave unset (or 0) once Azure AD credentials above are filled in.
AUTH_DEV_BYPASS=1

# Comma-separated list of @vienovo.ph emails who get the "Admin" nav link
# and access to /admin/*. Bootstrap method until role is moved into MongoDB.
ADMIN_EMAILS=jerome.corpus@vienovo.ph

# ─── Google Sheets ─────────────────────────────────────────────────────
# Path to the service account JSON key file. Generate one in Google Cloud
# Console and share the master sheet with the service account's email.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./.secrets/google-sheets-sa.json
GOOGLE_SHEETS_MASTER_ID=1Sj-3cqo3k9RwTH2r4QOyGckyzboC4Z3zG5VNaTeGFj8

# Cloudinary (form attachments)
# Create an API key/secret in Cloudinary Console -> Settings -> API Keys.
# Optional: CLOUDINARY_UPLOAD_FOLDER defaults to "vienovo-forms".
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=vienovo-forms

# ─── Microsoft Graph (for Teams notifications, milestone 6) ────────────
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

# ─── Email (Resend, milestone 6) ───────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=SAP <sap@vienovo.ph>

# Email (SMTP notifications)
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SAP <sap@vienovo.ph>
# Optional (defaults work for Office365)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=0
