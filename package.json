{
  "name": "vienovo-forms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "smoke:buttons": "node scripts/smoke-buttons.mjs",
    "health:system": "node scripts/health-system.mjs",
    "health:system:auto": "node scripts/health-system.mjs --start-server",
    "verify": "npm run typecheck && npm run build",
    "db:backfill-request-queue": "node scripts/backfill-request-queue-fields.mjs",
    "db:backfill-import-diagnostics": "node scripts/backfill-import-diagnostics.mjs",
    "db:validate-import-registry": "node scripts/validate-import-registry-consistency.mjs",
    "db:repair-import-registry": "node scripts/repair-import-registry-links.mjs --apply",
    "db:resync-builtins": "node scripts/resync-built-in-forms.mjs",
    "db:sync-fixed-assets-forms": "node scripts/sync-fixed-assets-forms.mjs",
    "db:detect-orphaned-form-slugs": "node scripts/detect-orphaned-request-form-slugs.mjs",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f mongo"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.9.0",
    "lucide-react": "^0.469.0",
    "mongoose": "^9.6.1",
    "next": "^15.5.15",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
